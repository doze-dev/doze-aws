# Runtime data — service stores are never committed.
/data/
*.db
*.bolt

# Build output.
/bin/
/dist/
/doze-aws

# Go test / coverage artifacts.
*.test
*.out
coverage.*

# Editor / OS noise.
.DS_Store

# e2e/ (Playwright/Bun toolchain — bun.lock IS committed).
e2e/node_modules/
e2e/.tmp/
e2e/playwright-report/
e2e/test-results/
e2e/blob-report/
e2e/.bun/
